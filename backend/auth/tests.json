{
  "tests": [
    {
      "name": "OPTIONS preflight",
      "method": "OPTIONS",
      "path": "/?action=register",
      "expectedStatus": 200
    },
    {
      "name": "Login existing client",
      "method": "POST",
      "path": "/?action=login",
      "body": {"email": "test_client@example.com", "password": "test123"},
      "expectedStatus": 200,
      "expectedBody": {"token": "string"},
      "bodyMatcher": "partial"
    },
    {
      "name": "Login wrong password",
      "method": "POST",
      "path": "/?action=login",
      "body": {"email": "test_client@example.com", "password": "wrongpass"},
      "expectedStatus": 400,
      "expectedBody": {"error": "string"},
      "bodyMatcher": "partial"
    },
    {
      "name": "Packages list",
      "method": "GET",
      "path": "/?action=packages",
      "expectedStatus": 200,
      "expectedBody": {"packages": [{"id": "start", "estimates": 5}]},
      "bodyMatcher": "partial"
    }
  ]
}