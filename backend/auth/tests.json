{
  "tests": [
    {
      "name": "OPTIONS preflight",
      "method": "OPTIONS",
      "path": "/?action=register",
      "expectedStatus": 200
    },
    {
      "name": "Login existing client",
      "method": "POST",
      "path": "/?action=login",
      "body": {"email": "test_client@example.com", "password": "test123"},
      "expectedStatus": 200,
      "expectedBody": {"token": "string"},
      "bodyMatcher": "partial"
    },
    {
      "name": "Login wrong password",
      "method": "POST",
      "path": "/?action=login",
      "body": {"email": "test_client@example.com", "password": "wrongpass"},
      "expectedStatus": 400,
      "expectedBody": {"error": "string"},
      "bodyMatcher": "partial"
    },
    {
      "name": "Packages list",
      "method": "GET",
      "path": "/?action=packages",
      "expectedStatus": 200
    },
    {
      "name": "WL login wrong password",
      "method": "POST",
      "path": "/?action=wl-login",
      "body": {"email": "nobody@example.com", "password": "wrong"},
      "expectedStatus": 400,
      "expectedBody": {"error": "string"},
      "bodyMatcher": "partial"
    },
    {
      "name": "WL staff list unauthorized",
      "method": "GET",
      "path": "/?action=wl-staff-list",
      "expectedStatus": 401,
      "expectedBody": {"error": "string"},
      "bodyMatcher": "partial"
    }
  ]
}