{
  "tests": [
    {
      "name": "OPTIONS preflight",
      "method": "OPTIONS",
      "path": "/?action=register",
      "expectedStatus": 200
    },
    {
      "name": "Register new user",
      "method": "POST",
      "path": "/?action=register",
      "body": {"email": "test_auth@example.com", "password": "test123", "name": "Тест"},
      "expectedStatus": 200,
      "expectedBody": {"token": "string"},
      "bodyMatcher": "partial"
    },
    {
      "name": "Login existing user",
      "method": "POST",
      "path": "/?action=login",
      "body": {"email": "test_auth@example.com", "password": "test123"},
      "expectedStatus": 200,
      "expectedBody": {"token": "string"},
      "bodyMatcher": "partial"
    },
    {
      "name": "Login wrong password",
      "method": "POST",
      "path": "/?action=login",
      "body": {"email": "test_auth@example.com", "password": "wrongpass"},
      "expectedStatus": 400,
      "expectedBody": {"error": "string"},
      "bodyMatcher": "partial"
    }
  ]
}
