{
  "tests": [
    {
      "name": "OPTIONS preflight",
      "method": "OPTIONS",
      "path": "/?action=register",
      "expectedStatus": 200
    },
    {
      "name": "Login existing client",
      "method": "POST",
      "path": "/?action=login",
      "body": {"email": "test_client@example.com", "password": "test123"},
      "expectedStatus": 200,
      "expectedBody": {"token": "string"},
      "bodyMatcher": "partial"
    },
    {
      "name": "Login wrong password",
      "method": "POST",
      "path": "/?action=login",
      "body": {"email": "test_client@example.com", "password": "wrongpass"},
      "expectedStatus": 400,
      "expectedBody": {"error": "string"},
      "bodyMatcher": "partial"
    },
    {
      "name": "Verify email missing code",
      "method": "POST",
      "path": "/?action=verify-email",
      "body": {"email": "test_client@example.com"},
      "expectedStatus": 400,
      "expectedBody": {"error": "string"},
      "bodyMatcher": "partial"
    },
    {
      "name": "Telegram callback invalid hash",
      "method": "POST",
      "path": "/?action=telegram-callback",
      "body": {"id": 1, "first_name": "Test", "auth_date": 1700000000, "hash": "invalid"},
      "expectedStatus": 400,
      "expectedBody": {"error": "string"},
      "bodyMatcher": "partial"
    },
    {
      "name": "Telegram bot id",
      "method": "GET",
      "path": "/?action=telegram-bot-id",
      "expectedStatus": 200,
      "expectedBody": {"bot_id": "string"},
      "bodyMatcher": "partial"
    },
    {
      "name": "Packages list",
      "method": "GET",
      "path": "/?action=packages",
      "expectedStatus": 200
    },
    {
      "name": "WL login wrong password",
      "method": "POST",
      "path": "/?action=wl-login",
      "body": {"email": "nobody@example.com", "password": "wrong"},
      "expectedStatus": 400,
      "expectedBody": {"error": "string"},
      "bodyMatcher": "partial"
    },
    {
      "name": "WL staff list unauthorized",
      "method": "GET",
      "path": "/?action=wl-staff-list",
      "expectedStatus": 401,
      "expectedBody": {"error": "string"},
      "bodyMatcher": "partial"
    },
    {
      "name": "Create demo user",
      "method": "POST",
      "path": "/?action=create-demo",
      "expectedStatus": 200,
      "expectedBody": {"token": "string", "user": {"is_demo": true}},
      "bodyMatcher": "partial"
    },
    {
      "name": "Cleanup demo users",
      "method": "POST",
      "path": "/?action=cleanup-demo",
      "expectedStatus": 200,
      "bodyMatcher": "partial"
    },
    {
      "name": "Team roles list unauthorized",
      "method": "GET",
      "path": "/?action=team-roles-list",
      "expectedStatus": 401,
      "expectedBody": {"error": "string"},
      "bodyMatcher": "partial"
    },
    {
      "name": "Unlink provider unauthorized",
      "method": "POST",
      "path": "/?action=unlink-provider",
      "body": {"provider": "google"},
      "expectedStatus": 401,
      "expectedBody": {"error": "string"},
      "bodyMatcher": "partial"
    },
    {
      "name": "Team toggle active unauthorized",
      "method": "POST",
      "path": "/?action=team-toggle-active",
      "body": {"member_id": 1, "active": false},
      "expectedStatus": 401,
      "expectedBody": {"error": "string"},
      "bodyMatcher": "partial"
    }
  ]
}