{
  "tests": [
    {
      "name": "OPTIONS preflight",
      "method": "OPTIONS",
      "path": "/?action=register",
      "expectedStatus": 200
    },

    {
      "name": "Login existing client",
      "method": "POST",
      "path": "/?action=login",
      "body": {"email": "test_client@example.com", "password": "test123"},
      "expectedStatus": 200,
      "expectedBody": {"token": "string"},
      "bodyMatcher": "partial"
    },
    {
      "name": "Login wrong password",
      "method": "POST",
      "path": "/?action=login",
      "body": {"email": "test_client@example.com", "password": "wrongpass"},
      "expectedStatus": 400,
      "expectedBody": {"error": "string"},
      "bodyMatcher": "partial"
    },
    {
      "name": "Pending users (business)",
      "method": "GET",
      "path": "/?action=pending-users&role_group=business",
      "expectedStatus": 200,
      "expectedBody": {"users": "array"},
      "bodyMatcher": "partial"
    },
    {
      "name": "Pro users (designers/foremen)",
      "method": "GET",
      "path": "/?action=pro-users",
      "expectedStatus": 200,
      "expectedBody": {"users": "array"},
      "bodyMatcher": "partial"
    },
    {
      "name": "Removed users (all groups)",
      "method": "GET",
      "path": "/?action=removed-users&group=all",
      "expectedStatus": 200,
      "expectedBody": {"users": []},
      "bodyMatcher": "partial"
    }
  ]
}