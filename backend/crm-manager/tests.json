{
  "tests": [
    {
      "name": "OPTIONS preflight",
      "method": "OPTIONS",
      "path": "/",
      "expectedStatus": 200
    },
    {
      "name": "GET stats",
      "method": "GET",
      "path": "/?r=stats",
      "expectedStatus": 200
    },
    {
      "name": "GET clients",
      "method": "GET",
      "path": "/?r=clients",
      "expectedStatus": 200
    },
    {
      "name": "GET kanban columns",
      "method": "GET",
      "path": "/?r=kanban-columns",
      "expectedStatus": 200
    },
    {
      "name": "GET kanban cards",
      "method": "GET",
      "path": "/?r=kanban-cards",
      "expectedStatus": 200
    },
    {
      "name": "GET calendar events",
      "method": "GET",
      "path": "/?r=calendar-events",
      "expectedStatus": 200
    },
    {
      "name": "GET client files",
      "method": "GET",
      "path": "/?r=client_files&client_id=1",
      "expectedStatus": 200
    },
    {
      "name": "GET substatuses",
      "method": "GET",
      "path": "/?r=substatuses",
      "expectedStatus": 200
    },
    {
      "name": "GET plan-projects",
      "method": "GET",
      "path": "/?r=plan-projects",
      "expectedStatus": 200
    },
    {
      "name": "GET plan-rooms-by-chat missing chat_id",
      "method": "GET",
      "path": "/?r=plan-rooms-by-chat",
      "expectedStatus": 400,
      "expectedBody": {"error": "chat_id required"},
      "bodyMatcher": "partial"
    },
    {
      "name": "GET plan-crm-sync missing project_id",
      "method": "GET",
      "path": "/?r=plan-crm-sync&project_id=0",
      "expectedStatus": 404,
      "expectedBody": {"error": "not found"},
      "bodyMatcher": "partial"
    },
    {
      "name": "GET plan-share missing token",
      "method": "GET",
      "path": "/?r=plan-share",
      "expectedStatus": 400,
      "expectedBody": {"error": "token required"},
      "bodyMatcher": "partial"
    },
    {
      "name": "GET bug_reports",
      "method": "GET",
      "path": "/?r=bug_reports",
      "expectedStatus": 200
    },
    {
      "name": "POST bug_report",
      "method": "POST",
      "path": "/?r=bug_reports",
      "body": {"description": "Тестовый баг-репорт", "severity": "normal", "report_type": "bug"},
      "expectedStatus": 200
    }
  ]
}